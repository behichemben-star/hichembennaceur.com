<!-- Page scripts -->
<script>
  // Lucide icons
  if (typeof lucide !== 'undefined') lucide.createIcons();

  // Scroll progress bar
  const bar = document.getElementById('scroll-progress');
  window.addEventListener('scroll', () => {
    const pct = (window.scrollY / (document.documentElement.scrollHeight - window.innerHeight)) * 100;
    if (bar) bar.style.width = pct + '%';
  }, { passive: true });

  // Intersection Observer — scroll reveals
  const obs = new IntersectionObserver(
    (entries) => entries.forEach(e => {
      if (e.isIntersecting) { e.target.classList.add('in-view'); obs.unobserve(e.target); }
    }),
    { threshold: 0.07, rootMargin: '0px 0px -28px 0px' }
  );
  document.querySelectorAll('.reveal, .reveal-scale, .reveal-blur').forEach(el => obs.observe(el));

  // Fire hero animations immediately
  document.querySelectorAll('.hero .reveal, .hero .reveal-blur').forEach(el => {
    const delay = parseInt(el.style.getPropertyValue('--delay') || '0') || 0;
    setTimeout(() => el.classList.add('in-view'), delay);
  });
  // Fire hero tag too
  document.querySelector('.hero-tag')?.classList.add('in-view');

  // 3D tilt on cards
  document.querySelectorAll('.solution-card, .cost-card, .pain-item').forEach(card => {
    card.addEventListener('mousemove', e => {
      const r = card.getBoundingClientRect();
      const dx = (e.clientX - r.left - r.width / 2) / (r.width / 2);
      const dy = (e.clientY - r.top - r.height / 2) / (r.height / 2);
      card.style.transition = 'transform 0.05s ease';
      card.style.transform = `perspective(900px) rotateY(${dx * 5}deg) rotateX(${-dy * 5}deg) translateZ(5px)`;
    });
    card.addEventListener('mouseleave', () => {
      card.style.transition = 'transform 0.45s cubic-bezier(0.16, 1, 0.3, 1)';
      card.style.transform = '';
    });
  });
</script>

