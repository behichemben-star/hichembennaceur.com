  /* ─── ANIMATION SYSTEM (Enhanced) ─── */

  /* Base: dramatic fade + rise */
  .reveal {
    opacity: 0;
    transform: translateY(56px);
    will-change: opacity, transform;
    transition:
      opacity 0.95s cubic-bezier(0.16, 1, 0.3, 1),
      transform 0.95s cubic-bezier(0.16, 1, 0.3, 1);
    transition-delay: var(--delay, 0ms);
  }
  .reveal.in-view {
    opacity: 1;
    transform: translateY(0);
  }

  /* Slide from left with subtle rotation */
  .reveal-left {
    opacity: 0;
    transform: translateX(-72px) rotate(-2.5deg);
    will-change: opacity, transform;
    transition:
      opacity 0.9s cubic-bezier(0.16, 1, 0.3, 1),
      transform 0.9s cubic-bezier(0.16, 1, 0.3, 1);
    transition-delay: var(--delay, 0ms);
  }
  .reveal-left.in-view {
    opacity: 1;
    transform: translateX(0) rotate(0deg);
  }

  /* Slide from right with subtle rotation */
  .reveal-right {
    opacity: 0;
    transform: translateX(72px) rotate(2.5deg);
    will-change: opacity, transform;
    transition:
      opacity 0.9s cubic-bezier(0.16, 1, 0.3, 1),
      transform 0.9s cubic-bezier(0.16, 1, 0.3, 1);
    transition-delay: var(--delay, 0ms);
  }
  .reveal-right.in-view {
    opacity: 1;
    transform: translateX(0) rotate(0deg);
  }

  /* Scale pop — deep bounce spring physics */
  .reveal-scale {
    opacity: 0;
    transform: scale(0.78) translateY(40px);
    will-change: opacity, transform;
    transition:
      opacity 0.75s cubic-bezier(0.34, 1.56, 0.64, 1),
      transform 0.75s cubic-bezier(0.34, 1.56, 0.64, 1);
    transition-delay: var(--delay, 0ms);
  }
  .reveal-scale.in-view {
    opacity: 1;
    transform: scale(1) translateY(0);
  }

  /* Blur + fade — cinematic depth-of-field */
  .reveal-blur {
    opacity: 0;
    transform: translateY(40px);
    filter: blur(18px);
    will-change: opacity, transform, filter;
    transition:
      opacity 1.2s cubic-bezier(0.16, 1, 0.3, 1),
      transform 1.2s cubic-bezier(0.16, 1, 0.3, 1),
      filter 1s cubic-bezier(0.16, 1, 0.3, 1);
    transition-delay: var(--delay, 0ms);
  }
  .reveal-blur.in-view {
    opacity: 1;
    transform: translateY(0);
    filter: blur(0);
  }

  /* Clip wipe — left to right reveal */
  .reveal-clip {
    clip-path: inset(0 100% 0 0);
    opacity: 0;
    will-change: clip-path, opacity;
    transition:
      clip-path 0.9s cubic-bezier(0.16, 1, 0.3, 1),
      opacity 0.4s ease;
    transition-delay: var(--delay, 0ms);
  }
  .reveal-clip.in-view {
    clip-path: inset(0 0% 0 0);
    opacity: 1;
  }

  /* Hero photo: dramatic entrance */
  .reveal-photo {
    opacity: 0;
    transform: translateX(64px) scale(0.88) rotate(3deg);
    will-change: opacity, transform;
    transition:
      opacity 1.3s cubic-bezier(0.16, 1, 0.3, 1),
      transform 1.3s cubic-bezier(0.16, 1, 0.3, 1);
    transition-delay: var(--delay, 200ms);
  }
  .reveal-photo.in-view {
    opacity: 1;
    transform: translateX(0) scale(1) rotate(0deg);
  }

  /* Counter number */
  .count-up { font-variant-numeric: tabular-nums; }

  /* ─── HERO PHOTO FLOAT ─── */
  @keyframes heroFloat {
    0%, 100% { transform: translateY(0px); }
    25%       { transform: translateY(-10px) rotate(0.5deg); }
    75%       { transform: translateY(-6px) rotate(-0.5deg); }
  }
  .hero-photo-circle {
    animation: heroFloat 7s ease-in-out 1.6s infinite;
  }

  /* ─── CTA BUTTON SHIMMER ─── */
  .btn-primary {
    position: relative;
    overflow: hidden;
  }
  .btn-primary::after {
    content: '';
    position: absolute;
    top: 0;
    left: -90%;
    width: 55%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.28), transparent);
    transform: skewX(-20deg);
    pointer-events: none;
    transition: none;
  }
  .btn-primary:hover::after {
    animation: btnShimmer 0.6s ease forwards;
  }
  @keyframes btnShimmer {
    from { left: -90%; }
    to   { left: 150%; }
  }

  /* ─── SCROLL PROGRESS ─── */
  .scroll-progress {
    position: fixed;
    top: 0;
    left: 0;
    height: 3px;
    width: 0%;
    background: linear-gradient(90deg, var(--orange) 0%, #ff6535 50%, #ff8855 100%);
    box-shadow: 0 0 12px rgba(231,74,26,0.65);
    z-index: 999;
    pointer-events: none;
    transform-origin: left center;
  }

  /* ─── NAV LINK HOVER UNDERLINE ─── */
