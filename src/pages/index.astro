---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Hichem Bennaceur — Analytics & CRO Consultant" description="I take care of your Analytics and CRO, to enable data-driven decision-making and fuel your growth.">

<style>
  /* ─── Satoshi Font ─── */
  @import url('https://api.fontshare.com/v2/css?f[]=satoshi@900,700,500,400&display=swap');

  /* ─── Design Tokens ─── */
  :root {
    --cream: #F9F8F2;
    --cream-dark: #F2EDE3;
    --orange: #E74A1A;
    --blue: #17488B;
    --black: #0A0A0A;
    --text: #101010;
    --muted: #666;
    --border: 1px solid #E5E3DA;
    --radius: 12px;
    --shadow-sm: 0 1px 4px rgba(0,0,0,0.07);
    --shadow: 0 2px 12px rgba(0,0,0,0.08);
    --shadow-md: 0 4px 24px rgba(0,0,0,0.1);
    --font: 'Satoshi', sans-serif;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  body { font-family: var(--font); background: var(--cream); color: var(--text); line-height: 1.6; overflow-x: hidden; }
  img { max-width: 100%; display: block; }
  a { color: inherit; text-decoration: none; }

  /* ─── NAV ─── */
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(249, 248, 242, 0.92);
    backdrop-filter: blur(12px);
    border-bottom: var(--border);
    padding: 0 48px;
    height: 64px;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 24px;
  }
  .nav-logo {
    font-weight: 700;
    font-size: 14px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text);
    white-space: nowrap;
  }
  .nav-links {
    display: flex;
    align-items: center;
    gap: 32px;
    list-style: none;
    justify-content: center;
  }
  .nav-links a {
    font-size: 14px;
    font-weight: 500;
    color: var(--muted);
    transition: color 0.2s;
    cursor: pointer;
    white-space: nowrap;
  }
  .nav-links a:hover { color: var(--text); }
  .nav-right {
    display: flex;
    justify-content: flex-end;
    align-items: center;
  }
  .nav-badge {
    display: flex;
    align-items: center;
    gap: 7px;
    background: #fff;
    border: var(--border);
    border-radius: 1000px;
    padding: 7px 16px 7px 10px;
    font-size: 13px;
    font-weight: 600;
    color: var(--text);
    box-shadow: var(--shadow-sm);
    cursor: pointer;
    transition: box-shadow 0.2s;
    white-space: nowrap;
  }
  .nav-badge:hover { box-shadow: var(--shadow); }
  .nav-dot {
    width: 8px; height: 8px;
    flex-shrink: 0;
    border-radius: 50%;
    background: #22C55E;
    animation: pulse-green 2s infinite;
  }
  @keyframes pulse-green {
    0%, 100% { box-shadow: 0 0 0 0 rgba(34,197,94,0.4); }
    50% { box-shadow: 0 0 0 5px rgba(34,197,94,0); }
  }

  /* ─── HERO ─── */
  .hero-section-wrap {
    background:
      radial-gradient(ellipse 55% 70% at 92% 5%, rgba(231,74,26,0.09), transparent 65%),
      radial-gradient(ellipse 35% 40% at 5% 95%, rgba(23,72,139,0.05), transparent 60%),
      var(--cream);
    position: relative;
    overflow: hidden;
  }
  .hero {
    padding: 32px 28px 48px;
    max-width: 1280px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 420px);
    gap: 32px 40px;
    align-items: start;
  }
  .hero-tag {
    display: inline-block;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--orange);
    margin-bottom: 14px;
  }
  .hero-title {
    font-size: clamp(32px, 4.2vw, 50px);
    font-weight: 900;
    line-height: 1.12;
    letter-spacing: -0.02em;
    margin-bottom: 18px;
    color: var(--text);
  }
  /* Single orange accent — everything else is dark */
  .hero-title .orange { color: var(--orange); }
  /* Typographic emphasis via italic, no extra color */
  .hero-title .italic-em { font-style: italic; color: var(--text); }
  /* Orange underline, dark text — editorial accent */
  .hero-title .underline-accent {
    color: var(--text);
    text-decoration: underline;
    text-decoration-color: var(--orange);
    text-underline-offset: 5px;
    text-decoration-thickness: 3px;
  }
  .hero-sub {
    font-size: 17px;
    color: var(--muted);
    max-width: 560px;
    margin-bottom: 28px;
    line-height: 1.7;
  }
  .hero-actions {
    display: flex;
    align-items: center;
    gap: 24px;
    flex-wrap: wrap;
    margin-bottom: 24px;
  }
  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--orange);
    color: #fff;
    font-family: var(--font);
    font-size: 15px;
    font-weight: 700;
    border-radius: 1000px;
    padding: 14px 28px;
    border: none;
    cursor: pointer;
    transition: transform 0.18s, box-shadow 0.18s;
    box-shadow: 0 2px 12px rgba(231,74,26,0.3);
  }
  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(231,74,26,0.35);
  }
  /* Senja hero widget — constrained width so it doesn't sprawl */
  .hero-senja {
    max-width: 420px;
    width: 100%;
  }

  /* Right: photo — center in row vs text column without forcing full viewport height */
  .hero-photo-wrap {
    display: flex;
    justify-content: center;
    align-items: center;
    align-self: center;
  }
  .hero-photo-circle {
    width: 320px;
    overflow: hidden;
    /* Fade out the bottom ~25% where the orange baked into the PNG lives */
    -webkit-mask-image: linear-gradient(to bottom, black 65%, transparent 92%);
    mask-image: linear-gradient(to bottom, black 65%, transparent 92%);
  }
  .hero-photo {
    width: 100%;
    height: auto;
    display: block;
    filter: drop-shadow(0 8px 32px rgba(0,0,0,0.14));
  }

  /* ─── LOGO BAR ─── */
  .logo-bar {
    background: var(--cream-dark);
    border-top: var(--border);
    border-bottom: var(--border);
    padding: 28px 48px;
    display: flex;
    align-items: center;
    gap: 48px;
    overflow: hidden;
  }
  .logo-bar-stat {
    flex-shrink: 0;
    border-right: var(--border);
    padding-right: 48px;
  }
  .logo-bar-stat .stat-num {
    font-size: 32px;
    font-weight: 900;
    color: var(--text);
    line-height: 1;
  }
  .logo-bar-stat .stat-label {
    font-size: 12px;
    color: var(--muted);
    font-weight: 500;
    margin-top: 4px;
  }
  .logo-bar-stat .stars-row {
    display: flex;
    gap: 2px;
    margin-top: 6px;
  }
  .star { color: var(--orange); font-size: 14px; }
  .logo-marquee {
    flex: 1;
    overflow: hidden;
    mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
  }
  .logo-track {
    display: flex;
    align-items: center;
    gap: 48px;
    animation: marquee 22s linear infinite;
    width: max-content;
  }
  /* Each marquee logo lives in a fixed-height box for visual consistency */
  .logo-track .logo-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 32px;
    max-width: 120px;
    flex-shrink: 0;
  }
  .logo-track .logo-wrap img {
    max-height: 32px;
    max-width: 120px;
    width: auto;
    height: auto;
    object-fit: contain;
    opacity: 0.85;
    transition: opacity 0.2s;
  }
  .logo-track .logo-wrap img:hover { opacity: 1; }
  @keyframes marquee {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  /* ─── SECTIONS ─── */
  .section {
    padding: 96px 48px;
    max-width: 1200px;
    margin: 0 auto;
  }
  .section-label {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 16px;
    text-align:center;
  }
  .section-title {
    font-size: clamp(28px, 3vw, 40px);
    font-weight: 900;
    letter-spacing: -0.02em;
    line-height: 1.15;
    color: var(--text);
  }
  .section-title .highlight {
    color: var(--orange);
  }
  .section-title .blue { color: var(--blue); font-style: italic; }
  /* Centered section header modifier */
  .section-header-centered {
    text-align: center;
    margin-bottom: 48px;
  }
  .section-header-centered .section-label { display: block; }
  .section-divider {
    border: none;
    border-top: var(--border);
  }

  /* ─── WHY ME ─── */
  .why-grid {
    display: grid;
    grid-template-columns: 380px 1fr;
    gap: 64px;
    align-items: start;
    margin-top: 56px;
  }
  /* Label shares .section-label (centered globally); left-align here to match headline */
  .why-grid .section-label {
    text-align: left;
  }
  .why-headline {
    font-size: clamp(28px, 3vw, 38px);
    font-weight: 900;
    letter-spacing: -0.02em;
    line-height: 1.2;
    color: var(--blue);
  }
  .why-headline em {
    font-style: italic;
    font-weight: 900;
  }
  .why-items {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .why-item {
    background: #fff;
    border: var(--border);
    border-radius: var(--radius);
    padding: 20px 24px;
    display: grid;
    grid-template-columns: 28px 1fr;
    gap: 16px;
    align-items: start;
    box-shadow: var(--shadow-sm);
    transition: box-shadow 0.2s, transform 0.2s;
  }
  .why-item:hover {
    box-shadow: var(--shadow);
    transform: translateY(-1px);
  }
  .why-item-num {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: var(--cream-dark);
    border: var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    font-weight: 700;
    color: var(--text);
    flex-shrink: 0;
    margin-top: 2px;
  }
  .why-item-title {
    font-size: 15px;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 4px;
  }
  .why-item-body {
    font-size: 13px;
    color: var(--muted);
    line-height: 1.6;
  }

  /* ─── WHY ME WRAPPER ─── */
  .why-section-wrap {
    background: linear-gradient(160deg, #fff 0%, var(--cream) 50%, #eeeae0 100%);
    border-top: var(--border);
    border-bottom: var(--border);
  }

  /* ─── SERVICES WRAPPER ─── */
  .services-section-wrap {
    background:
      radial-gradient(ellipse 60% 50% at 50% 100%, rgba(231,74,26,0.04), transparent 70%),
      #fff;
    border-top: var(--border);
    border-bottom: var(--border);
  }

  /* ─── SKILLS ─── */
  .skills-section {
    background:
      radial-gradient(ellipse 70% 60% at 50% 0%, rgba(23,72,139,0.04), transparent 60%),
      var(--cream-dark);
    background-image:
      radial-gradient(ellipse 70% 60% at 50% 0%, rgba(23,72,139,0.04), transparent 60%),
      radial-gradient(circle, rgba(0,0,0,0.05) 1px, transparent 1px),
      linear-gradient(var(--cream-dark), var(--cream-dark));
    background-size: auto, 28px 28px, auto;
    border-top: var(--border);
    border-bottom: var(--border);
    padding: 96px 48px;
  }
  .skills-inner {
    max-width: 1200px;
    margin: 0 auto;
  }
  .skills-header {
    text-align: center;
    margin-bottom: 48px;
  }
  .cert-strip {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 24px;
    margin: 32px 0 48px;
    flex-wrap: wrap;
  }
  /* Fixed-size container so every logo occupies identical visual space */
  .cert-box {
    width: 120px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .cert-box img {
    width: 100%;
    height: 48px;
    object-fit: contain;
    opacity: 0.72;
    filter: grayscale(0.3);
    transition: opacity 0.2s, filter 0.2s;
  }
  .cert-box img:hover { opacity: 1; filter: grayscale(0); }
  /* cert-logo-4: file has heavy internal padding — scale so it matches neighbor logos */
  .cert-box--padded-source {
    width: 136px;
    overflow: visible;
  }
  .cert-box--padded-source img {
    transform: scale(1.72);
    transform-origin: center center;
  }
  .skills-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
  }
  .skill-tile {
    background: #fff;
    border: var(--border);
    border-radius: var(--radius);
    padding: 20px 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    box-shadow: var(--shadow-sm);
    transition: box-shadow 0.2s, transform 0.2s;
  }
  .skill-tile:hover {
    box-shadow: var(--shadow);
    transform: translateY(-2px);
  }
  .skill-name {
    font-size: 14px;
    font-weight: 700;
    color: var(--text);
  }
  .skill-stars {
    display: flex;
    gap: 2px;
  }
  .skill-stars span { color: var(--orange); font-size: 13px; }
  .skill-stars .empty { color: #DDD; }

  /* ─── SERVICES ─── */
  .services-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
    margin-top: 48px;
  }
  .service-card {
    background: #fff;
    border: var(--border);
    border-radius: var(--radius);
    padding: 32px 32px 28px;
    box-shadow: var(--shadow-sm);
    transition: box-shadow 0.22s, transform 0.22s;
    position: relative;
    overflow: hidden;
  }
  .service-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 4px;
  }
  .service-card:nth-child(1)::before { background: var(--orange); }
  .service-card:nth-child(2)::before { background: var(--blue); }
  .service-card:nth-child(3)::before { background: #22C55E; }
  .service-card:nth-child(4)::before { background: #A855F7; }
  .service-card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-3px);
  }
  .service-icon {
    font-size: 28px;
    margin-bottom: 16px;
  }
  .service-title {
    font-size: 18px;
    font-weight: 800;
    color: var(--text);
    margin-bottom: 12px;
    letter-spacing: -0.01em;
  }
  .service-body {
    font-size: 14px;
    color: var(--muted);
    line-height: 1.7;
    margin-bottom: 20px;
  }
  .service-card .service-body:last-child {
    margin-bottom: 0;
  }
  .service-link {
    font-size: 13px;
    font-weight: 700;
    color: var(--orange);
    display: flex;
    align-items: center;
    gap: 4px;
    transition: gap 0.18s;
  }
  .service-link:hover { gap: 8px; }

  /* ─── TAILORED SOLUTIONS ─── */
  .tailored-section {
    background:
      radial-gradient(ellipse 55% 60% at 95% 100%, rgba(231,74,26,0.18), transparent 65%),
      radial-gradient(ellipse 40% 40% at 5% 10%, rgba(23,72,139,0.12), transparent 55%),
      var(--text);
    color: #fff;
    padding: 96px 48px;
    position: relative;
  }
  .tailored-inner {
    max-width: 1200px;
    margin: 0 auto;
  }
  .tailored-header {
    text-align: center;
    margin-bottom: 16px;
  }
  .tailored-title {
    font-size: clamp(28px, 3vw, 40px);
    font-weight: 900;
    letter-spacing: -0.02em;
    color: #fff;
    margin-bottom: 12px;
  }
  .tailored-sub {
    font-size: 16px;
    color: rgba(255,255,255,0.55);
    max-width: 480px;
    margin: 0 auto 48px;
    line-height: 1.7;
  }
  .tailored-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }
  .tailored-card {
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: var(--radius);
    padding: 28px 28px 24px;
    transition: background 0.2s;
  }
  .tailored-card:hover { background: rgba(255,255,255,0.1); }
  .tailored-tag {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    border-radius: 1000px;
    padding: 4px 12px;
    margin-bottom: 20px;
  }
  .tailored-tag.agencies { background: rgba(231,74,26,0.2); color: #FF7A55; }
  .tailored-tag.ecommerce { background: rgba(34,197,94,0.2); color: #4ADE80; }
  .tailored-tag.saas { background: rgba(23,72,139,0.3); color: #60A5FA; }
  .tailored-card-title {
    font-size: 16px;
    font-weight: 800;
    color: #fff;
    margin-bottom: 12px;
    line-height: 1.35;
  }
  .tailored-card-body {
    font-size: 13px;
    color: rgba(255,255,255,0.5);
    line-height: 1.7;
    margin-bottom: 20px;
  }
  .tailored-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .tailored-list li {
    font-size: 13px;
    color: rgba(255,255,255,0.75);
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .tailored-list li::before {
    content: '✓';
    color: var(--orange);
    font-weight: 700;
    font-size: 12px;
  }
  .tailored-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-top: 20px;
    font-size: 13px;
    font-weight: 700;
    color: #4ADE80;
    text-decoration: none;
    transition: gap 0.2s ease;
  }
  .tailored-link:hover { gap: 10px; }

  /* ─── TESTIMONIALS ─── */
  .testimonials-outer {
    background: linear-gradient(180deg, var(--cream) 0%, #f0ece3 100%);
    border-top: var(--border);
    border-bottom: var(--border);
  }
  .testimonials-section {
    padding: 96px 48px;
    max-width: 1200px;
    margin: 0 auto;
  }
  .testimonials-header {
    text-align: center;
    margin-bottom: 16px;
  }
  .testimonials-title {
    font-size: clamp(28px, 3vw, 40px);
    font-weight: 900;
    letter-spacing: -0.02em;
    color: var(--text);
    margin-bottom: 8px;
  }
  .testimonials-sub {
    font-size: 14px;
    color: var(--muted);
    margin-bottom: 48px;
  }

  /* ─── BOOKING CALENDAR ─── */
  .audit-section {
    background: #fff;
    border-top: var(--border);
    border-bottom: var(--border);
    padding: 80px 48px;
  }
  .audit-inner {
    max-width: 900px;
    margin: 0 auto;
    text-align: center;
  }
  .audit-label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--orange);
    margin-bottom: 14px;
  }
  .audit-title {
    font-size: clamp(28px, 3.5vw, 44px);
    font-weight: 900;
    letter-spacing: -0.02em;
    line-height: 1.15;
    color: var(--text);
    margin-bottom: 16px;
  }
  .audit-sub {
    font-size: 16px;
    color: var(--muted);
    max-width: 560px;
    margin: 0 auto 40px;
    line-height: 1.7;
  }
  .cal-embed-wrap {
    width: 100%;
    height: 700px;
    border-radius: 16px;
    overflow: hidden;
    border: var(--border);
    box-shadow: 0 4px 32px rgba(0,0,0,0.07);
    background: #fff;
  }
  #my-cal-inline-30min {
    width: 100%;
    height: 100%;
    overflow: scroll;
  }
  @media (max-width: 600px) {
    .cal-embed-wrap { height: 800px; }
  }

  /* ─── FAQ ─── */
  .faq-section {
    padding: 96px 48px;
    max-width: 800px;
    margin: 0 auto;
  }
  .faq-header {
    text-align: center;
    margin-bottom: 48px;
  }
  .faq-item {
    border-bottom: var(--border);
  }
  .faq-item:first-of-type { border-top: var(--border); }
  details { padding: 4px 0; }
  summary {
    font-size: 16px;
    font-weight: 700;
    color: var(--text);
    padding: 20px 0;
    cursor: pointer;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    transition: color 0.18s;
    user-select: none;
  }
  summary:hover { color: var(--orange); }
  summary::after {
    content: '+';
    font-size: 22px;
    font-weight: 400;
    color: var(--muted);
    transition: transform 0.2s;
  }
  details[open] summary::after {
    content: '−';
    color: var(--orange);
  }
  .faq-body {
    font-size: 15px;
    color: var(--muted);
    line-height: 1.75;
    padding-bottom: 20px;
  }
  .faq-body strong { color: var(--text); }

  /* ─── FOOTER ─── */
  .footer {
    background: var(--text);
    color: rgba(255,255,255,0.6);
    padding: 48px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 24px;
  }
  .footer-logo {
    font-size: 15px;
    font-weight: 700;
