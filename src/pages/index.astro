    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0%;
    height: 2px;
    background: var(--orange);
    border-radius: 2px;
    transition: width 0.32s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .nav-links a:hover::after {
    width: 100%;
  }
</style>

