---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="White-label Analytics & CRO for Agencies — Hichem Bennaceur"
  description="Senior analytics and CRO execution for digital agencies. White-label, fixed pricing, delivered under your brand. Complex projects handled without bloating your headcount."
  canonicalUrl="https://hichembennaceur.com/agencies"
>

<style>
  @import url('https://api.fontshare.com/v2/css?f[]=satoshi@900,700,500,400&display=swap');

  :root {
    --cream: #F9F8F2;
    --cream-dark: #F2EDE3;
    --orange: #E74A1A;
    --blue: #17488B;
    --text: #101010;
    --muted: #666;
    --border: 1px solid #E5E3DA;
    --radius: 12px;
    --font: 'Satoshi', sans-serif;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  body { font-family: var(--font); background: var(--cream); color: var(--text); line-height: 1.6; overflow-x: hidden; }
  img { max-width: 100%; display: block; }
  a { color: inherit; text-decoration: none; }

  /* ─── SCROLL PROGRESS ─── */
  .scroll-progress {
    position: fixed; top: 0; left: 0; height: 3px; width: 0%;
    background: linear-gradient(90deg, var(--orange) 0%, #ff6535 50%, #ff8855 100%);
    box-shadow: 0 0 12px rgba(231,74,26,0.6);
    z-index: 999; pointer-events: none;
  }

  /* ─── NAV ─── */
  .nav {
    position: sticky; top: 0; z-index: 100;
    background: rgba(249,248,242,0.92);
    backdrop-filter: blur(12px);
    border-bottom: var(--border);
    padding: 0 48px; height: 64px;
    display: flex; align-items: center; justify-content: space-between; gap: 24px;
  }
  .nav-logo { font-weight: 700; font-size: 15px; letter-spacing: -0.01em; }
  .nav-logo:hover { color: var(--orange); }
  .nav-links { display: flex; align-items: center; gap: 28px; list-style: none; }
  .nav-links a { font-size: 14px; color: var(--muted); transition: color 0.2s; }
  .nav-links a:hover { color: var(--text); }
  .nav-cta {
    background: var(--orange); color: #fff; font-size: 13px; font-weight: 700;
    padding: 9px 20px; border-radius: 1000px;
    transition: opacity 0.2s, transform 0.2s; white-space: nowrap;
  }
  .nav-cta:hover { opacity: 0.88; transform: translateY(-1px); }

  /* ─── HERO ─── */
  .hero {
    padding: 88px 48px 72px;
    max-width: 960px;
    margin: 0 auto;
    text-align: center;
  }
  .hero-tag {
    display: inline-flex; align-items: center; gap: 8px;
    background: rgba(231,74,26,0.07);
    border: 1px solid rgba(231,74,26,0.18);
    color: var(--orange); font-size: 11px; font-weight: 700;
    letter-spacing: 0.1em; text-transform: uppercase;
    padding: 5px 14px; border-radius: 1000px; margin-bottom: 28px;
  }
  .hero-tag-dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--orange);
    animation: pulseDot 2s infinite;
  }
  @keyframes pulseDot {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.4; transform: scale(0.65); }
  }
  .hero-title {
    font-size: clamp(38px, 6vw, 72px);
    font-weight: 900; letter-spacing: -0.035em; line-height: 1.04;
    color: var(--text); margin-bottom: 24px;
  }
  .hero-title .orange { color: var(--orange); }
  .hero-title .underline-accent {
    text-decoration: underline;
    text-decoration-color: var(--orange);
    text-decoration-thickness: 3px;
    text-underline-offset: 6px;
  }
  .hero-sub {
    font-size: 18px; line-height: 1.72; color: var(--muted);
    max-width: 680px; margin: 0 auto 40px;
  }
  .hero-actions {
    display: flex; align-items: center; justify-content: center;
    gap: 16px; flex-wrap: wrap; margin-bottom: 32px;
  }
  .btn-primary {
    background: var(--orange); color: #fff; font-weight: 700; font-size: 15px;
    padding: 14px 28px; border-radius: 1000px;
    display: inline-flex; align-items: center; gap: 8px;
    transition: opacity 0.2s, transform 0.2s;
    position: relative; overflow: hidden;
  }
  .btn-primary:hover { opacity: 0.88; transform: translateY(-2px); }
  .btn-primary::after {
    content: ''; position: absolute; top: 0; left: -90%; width: 55%; height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.28), transparent);
    transform: skewX(-20deg); pointer-events: none;
  }
  .btn-primary:hover::after { animation: shimmer 0.6s ease forwards; }
  @keyframes shimmer { from { left: -90%; } to { left: 150%; } }
  .btn-ghost {
    font-size: 14px; color: var(--muted);
    display: inline-flex; align-items: center; gap: 6px;
    transition: color 0.2s;
  }
  .btn-ghost:hover { color: var(--text); }
  .trust-bar {
    display: flex; align-items: center; justify-content: center; gap: 8px;
    font-size: 13px; color: var(--muted);
  }
  .trust-stars { color: #F59E0B; letter-spacing: 2px; font-size: 14px; }

  /* ─── SECTION EYEBROW ─── */
  .eyebrow {
    font-size: 11px; font-weight: 700; letter-spacing: 0.1em;
    text-transform: uppercase; color: var(--orange); margin-bottom: 14px;
  }

  /* ─── PAIN SECTION ─── */
  .pain-section {
    background:
      radial-gradient(ellipse 55% 60% at 95% 0%, rgba(231,74,26,0.16), transparent 60%),
      radial-gradient(ellipse 40% 50% at 8% 100%, rgba(23,72,139,0.1), transparent 55%),
      #101010;
    color: #fff; padding: 96px 48px;
  }
  .pain-inner { max-width: 1160px; margin: 0 auto; }
  .pain-title {
    font-size: clamp(30px, 3.8vw, 48px); font-weight: 900;
    letter-spacing: -0.03em; line-height: 1.1; color: #fff;
    max-width: 760px; margin-bottom: 56px;
  }
  .pain-grid {
    display: grid; grid-template-columns: repeat(3, 1fr);
    gap: 2px; margin-bottom: 48px;
  }
  .pain-item {
    padding: 32px 28px;
    border: 1px solid rgba(255,255,255,0.07);
    background: rgba(255,255,255,0.03);
    transition: background 0.25s;
  }
  .pain-item:hover { background: rgba(255,255,255,0.07); }
  .pain-item:nth-child(1) { border-radius: 12px 0 0 0; }
  .pain-item:nth-child(2) { border-radius: 0; }
  .pain-item:nth-child(3) { border-radius: 0 12px 0 0; }
  .pain-item:nth-child(4) { border-radius: 0 0 0 12px; }
  .pain-item:nth-child(5) { border-radius: 0; }
  .pain-item:nth-child(6) { border-radius: 0 0 12px 0; }
  .pain-num {
    font-size: 11px; font-weight: 700; letter-spacing: 0.08em;
    color: rgba(231,74,26,0.65); margin-bottom: 12px;
  }
  .pain-item-title {
    font-size: 16px; font-weight: 800; color: #fff;
    margin-bottom: 10px; line-height: 1.35;
  }
  .pain-item-body {
    font-size: 13.5px; color: rgba(255,255,255,0.48); line-height: 1.72;
  }
  .pain-callout {
    background: rgba(231,74,26,0.09);
    border: 1px solid rgba(231,74,26,0.22);
    border-radius: 12px; padding: 28px 32px;
    display: flex; align-items: flex-start; gap: 16px;
  }
  .pain-callout-icon { font-size: 22px; flex-shrink: 0; margin-top: 2px; }
  .pain-callout-text {
    font-size: 15.5px; color: rgba(255,255,255,0.75); line-height: 1.7;
  }
  .pain-callout-text strong { color: #fff; }

  /* ─── PROOF SECTION (VIGGET) ─── */
  .proof-section {
    background: var(--cream-dark); border-top: var(--border); border-bottom: var(--border);
    padding: 88px 48px;
  }
  .proof-inner { max-width: 1000px; margin: 0 auto; }
  .proof-header { text-align: center; margin-bottom: 52px; }
  .proof-eyebrow { font-size: 11px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--orange); margin-bottom: 14px; }
  .proof-title {
    font-size: clamp(26px, 3.2vw, 40px); font-weight: 900;
    letter-spacing: -0.025em; color: var(--text); margin-bottom: 10px;
  }
  .proof-sub { font-size: 15px; color: var(--muted); max-width: 560px; margin: 0 auto; line-height: 1.68; }
  .proof-card {
    background: var(--cream);
    border: var(--border);
    border-radius: 16px;
    padding: 44px 48px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: center;
    position: relative;
    overflow: hidden;
  }
  .proof-card::before {
    content: ''; position: absolute;
    top: 0; left: 0; right: 0; height: 4px;
    background: linear-gradient(90deg, var(--orange), #ff6535);
  }
  .proof-badge {
    display: inline-flex; align-items: center; gap: 8px;
    background: rgba(231,74,26,0.08); border: 1px solid rgba(231,74,26,0.18);
    border-radius: 1000px; padding: 5px 14px;
    font-size: 11px; font-weight: 700; letter-spacing: 0.08em;
    text-transform: uppercase; color: var(--orange); margin-bottom: 20px;
  }
  .proof-card-title {
    font-size: clamp(20px, 2.4vw, 28px); font-weight: 900;
    letter-spacing: -0.02em; line-height: 1.2; color: var(--text); margin-bottom: 16px;
  }
  .proof-card-body {
    font-size: 15px; color: var(--muted); line-height: 1.75; margin-bottom: 24px;
  }
  .proof-list { list-style: none; display: flex; flex-direction: column; gap: 10px; }
  .proof-list li {
    font-size: 14px; color: var(--text);
    display: flex; align-items: flex-start; gap: 10px; line-height: 1.5;
  }
  .proof-list li::before { content: '✓'; color: var(--orange); font-weight: 700; font-size: 13px; flex-shrink: 0; margin-top: 1px; }
  .proof-quote {
    background: #101010;
    border-radius: 14px;
    padding: 36px 36px;
    position: relative;
  }
  .proof-quote-mark {
    font-size: 64px; line-height: 0.6; color: rgba(231,74,26,0.35);
    font-family: Georgia, serif; margin-bottom: 20px; display: block;
  }
  .proof-quote-text {
    font-size: 16px; color: rgba(255,255,255,0.82); line-height: 1.7;
    font-style: italic; margin-bottom: 24px;
  }
  .proof-quote-author {
    font-size: 13px; font-weight: 700; color: rgba(255,255,255,0.5);
    text-transform: uppercase; letter-spacing: 0.06em;
  }
  .proof-quote-author span { color: var(--orange); }

  /* ─── VALUE PROPS ─── */
  .value-section {
    background: var(--cream); border-top: var(--border);
    padding: 88px 48px;
  }
  .value-inner { max-width: 1160px; margin: 0 auto; }
  .value-header { text-align: center; margin-bottom: 56px; }
  .value-title {
    font-size: clamp(26px, 3.2vw, 40px); font-weight: 900;
    letter-spacing: -0.025em; color: var(--text); margin-bottom: 10px;
  }
  .value-sub { font-size: 15px; color: var(--muted); max-width: 480px; margin: 0 auto; }
  .value-grid {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px;
  }
  .value-card {
    background: var(--cream); border: var(--border); border-radius: var(--radius);
    padding: 32px 28px; position: relative; overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  .value-card::before {
    content: ''; position: absolute;
    top: 0; left: 0; right: 0; height: 3px; background: var(--orange);
  }
  .value-card-label {
    font-size: 11px; font-weight: 700; letter-spacing: 0.08em;
    text-transform: uppercase; color: var(--orange); margin-bottom: 10px;
  }
  .value-card-title {
    font-size: clamp(20px, 2.5vw, 28px); font-weight: 900;
    color: var(--text); letter-spacing: -0.03em; line-height: 1.1; margin-bottom: 8px;
  }
  .value-card-body { font-size: 13px; color: var(--muted); line-height: 1.68; }

  /* ─── SOLUTION SECTION ─── */
  .solution-section {
    background:
      radial-gradient(ellipse 45% 65% at 3% 50%, rgba(231,74,26,0.11), transparent 55%),
      radial-gradient(ellipse 50% 50% at 97% 10%, rgba(23,72,139,0.08), transparent 55%),
      #101010;
    color: #fff; padding: 96px 48px;
  }
  .solution-inner { max-width: 1160px; margin: 0 auto; }
  .solution-header { margin-bottom: 52px; }
  .solution-title {
    font-size: clamp(28px, 3.5vw, 46px); font-weight: 900;
    letter-spacing: -0.03em; line-height: 1.1; color: #fff;
    max-width: 620px; margin-bottom: 14px;
  }
  .solution-sub { font-size: 16px; color: rgba(255,255,255,0.48); max-width: 520px; line-height: 1.65; }
  .solution-grid {
    display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px;
  }
  .solution-card {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.09);
    border-radius: var(--radius); padding: 32px;
    transition: background 0.25s, border-color 0.25s;
  }
  .solution-card:hover { background: rgba(255,255,255,0.09); border-color: rgba(231,74,26,0.28); }
  .solution-icon {
    width: 46px; height: 46px; border-radius: 10px;
    background: rgba(231,74,26,0.14);
    border: 1px solid rgba(231,74,26,0.22);
    display: flex; align-items: center; justify-content: center;
    font-size: 20px; margin-bottom: 20px;
  }
  .solution-icon svg { width: 22px; height: 22px; stroke: var(--orange); stroke-width: 2; fill: none; stroke-linecap: round; stroke-linejoin: round; }
  .pain-callout-icon svg { width: 26px; height: 26px; stroke: rgba(231,74,26,0.85); stroke-width: 2; fill: none; stroke-linecap: round; stroke-linejoin: round; flex-shrink: 0; }
  .solution-card-title {
    font-size: 18px; font-weight: 800; color: #fff;
    margin-bottom: 10px; line-height: 1.3;
  }
  .solution-card-body {
    font-size: 14px; color: rgba(255,255,255,0.48); line-height: 1.72; margin-bottom: 24px;
  }
  .deliverables {
    list-style: none; display: flex; flex-direction: column; gap: 9px;
    border-top: 1px solid rgba(255,255,255,0.07); padding-top: 20px;
  }
  .deliverables li {
    font-size: 13px; color: rgba(255,255,255,0.62);
    display: flex; align-items: flex-start; gap: 8px; line-height: 1.5;
  }
  .deliverables li::before { content: '→'; color: var(--orange); font-weight: 700; font-size: 12px; flex-shrink: 0; margin-top: 2px; }

  /* ─── PROCESS ─── */
  .process-section {
    background: var(--cream); border-top: var(--border); padding: 96px 48px;
  }
  .process-inner { max-width: 1160px; margin: 0 auto; }
  .process-header { text-align: center; margin-bottom: 64px; }
  .process-title {
    font-size: clamp(26px, 3.2vw, 42px); font-weight: 900;
    letter-spacing: -0.025em; color: var(--text); margin-bottom: 12px;
  }
  .process-sub { font-size: 15px; color: var(--muted); }
  .process-steps {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 40px;
    position: relative;
  }
  .process-connector {
    position: absolute; top: 35px;
    left: calc(33.33% + 4px); right: calc(33.33% + 4px); height: 2px;
    background: linear-gradient(90deg, var(--orange) 0%, rgba(231,74,26,0.15) 100%);
    pointer-events: none;
  }
  .process-step { text-align: center; }
  .step-num {
    width: 70px; height: 70px; border-radius: 50%;
    background: var(--orange); color: #fff;
    font-size: 22px; font-weight: 900;
    display: flex; align-items: center; justify-content: center;
    margin: 0 auto 20px; position: relative; z-index: 1;
    box-shadow: 0 6px 24px rgba(231,74,26,0.35);
  }
  .step-period {
    font-size: 11px; font-weight: 700; letter-spacing: 0.08em;
    text-transform: uppercase; color: var(--orange); margin-bottom: 8px;
  }
  .step-title {
    font-size: 18px; font-weight: 800; color: var(--text);
    letter-spacing: -0.01em; margin-bottom: 10px;
  }
  .step-body { font-size: 14px; color: var(--muted); line-height: 1.72; }

  /* ─── VS TABLE ─── */
  .vs-section {
    background: var(--cream-dark); border-top: var(--border); border-bottom: var(--border);
    padding: 88px 48px;
  }
  .vs-inner { max-width: 960px; margin: 0 auto; }
  .vs-header { text-align: center; margin-bottom: 48px; }
  .vs-title {
    font-size: clamp(24px, 3vw, 38px); font-weight: 900;
    letter-spacing: -0.025em; color: var(--text); margin-bottom: 10px;
  }
  .vs-sub { font-size: 15px; color: var(--muted); }
  .vs-table {
    width: 100%; border-collapse: separate; border-spacing: 0;
    border: var(--border); border-radius: 14px; overflow: hidden;
  }
  .vs-table th {
    padding: 14px 22px; font-size: 11px; font-weight: 700;
    letter-spacing: 0.08em; text-transform: uppercase; text-align: left;
  }
  .vs-table th:first-child { background: rgba(0,0,0,0.04); color: var(--muted); border-right: var(--border); width: 26%; }
  .vs-table th.col-bad { background: rgba(0,0,0,0.04); color: var(--muted); border-right: var(--border); }
  .vs-table th.col-good { background: rgba(231,74,26,0.06); color: var(--orange); }
  .vs-table td {
    padding: 15px 22px; font-size: 13.5px;
    border-top: var(--border); line-height: 1.5; vertical-align: middle;
  }
  .vs-table td:first-child {
    font-weight: 600; background: rgba(0,0,0,0.02);
    border-right: var(--border); color: var(--text);
  }
  .vs-table td.bad { color: var(--muted); border-right: var(--border); }
  .vs-table td.good { color: var(--text); font-weight: 500; }
  .chk { color: var(--orange); font-weight: 700; margin-right: 5px; }
  .crs { color: #ccc; margin-right: 5px; }

  /* ─── TESTIMONIALS ─── */
  .testi-section {
    padding: 88px 48px; background: var(--cream); border-top: var(--border);
  }
  .testi-inner { max-width: 1160px; margin: 0 auto; }
  .testi-header { text-align: center; margin-bottom: 48px; }
  .testi-title {
    font-size: clamp(24px, 3vw, 36px); font-weight: 900;
    letter-spacing: -0.025em; color: var(--text); margin-bottom: 8px;
  }
  .testi-sub { font-size: 14px; color: var(--muted); }

  /* ─── CTA SECTION ─── */
  .cta-section {
    background:
      radial-gradient(ellipse 55% 65% at 95% 100%, rgba(231,74,26,0.18), transparent 60%),
      radial-gradient(ellipse 45% 45% at 5% 10%, rgba(23,72,139,0.12), transparent 55%),
      #101010;
    color: #fff; padding: 100px 48px;
    text-align: center;
  }
  .cta-inner { max-width: 720px; margin: 0 auto; }
  .cta-title {
    font-size: clamp(34px, 5vw, 62px); font-weight: 900;
    letter-spacing: -0.035em; line-height: 1.06; color: #fff; margin-bottom: 20px;
  }
  .cta-sub {
    font-size: 17px; color: rgba(255,255,255,0.52);
    max-width: 520px; margin: 0 auto 40px; line-height: 1.72;
  }
  .cta-btn {
    background: var(--orange); color: #fff; font-weight: 700; font-size: 16px;
    padding: 16px 36px; border-radius: 1000px;
    display: inline-flex; align-items: center; gap: 10px;
    transition: opacity 0.2s, transform 0.2s;
    position: relative; overflow: hidden;
  }
  .cta-btn:hover { opacity: 0.88; transform: translateY(-2px); }
  .cta-btn::after {
    content: ''; position: absolute; top: 0; left: -90%; width: 55%; height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.28), transparent);
    transform: skewX(-20deg); pointer-events: none;
  }
  .cta-btn:hover::after { animation: shimmer 0.6s ease forwards; }
  .cta-note { margin-top: 16px; font-size: 13px; color: rgba(255,255,255,0.3); }
  .cal-embed { margin-top: 52px; }
  #agency-cal { min-height: 500px; }

  /* ─── FOOTER ─── */
  .footer {
    background: #0a0a0a; border-top: 1px solid rgba(255,255,255,0.07);
    padding: 28px 48px;
    display: flex; align-items: center; justify-content: space-between;
    gap: 16px; flex-wrap: wrap;
  }
  .footer-logo { font-size: 14px; font-weight: 700; color: rgba(255,255,255,0.5); }
  .footer-links { display: flex; gap: 24px; flex-wrap: wrap; }
  .footer-link { font-size: 13px; color: rgba(255,255,255,0.3); transition: color 0.2s; }
  .footer-link:hover { color: var(--orange); }

  /* ─── REVEAL ANIMATIONS ─── */
  .reveal {
    opacity: 0; transform: translateY(52px); will-change: opacity, transform;
    transition: opacity 0.95s cubic-bezier(0.16, 1, 0.3, 1), transform 0.95s cubic-bezier(0.16, 1, 0.3, 1);
    transition-delay: var(--delay, 0ms);
  }
  .reveal.in-view { opacity: 1; transform: translateY(0); }
  .reveal-scale {
    opacity: 0; transform: scale(0.8) translateY(36px); will-change: opacity, transform;
    transition: opacity 0.72s cubic-bezier(0.34, 1.56, 0.64, 1), transform 0.72s cubic-bezier(0.34, 1.56, 0.64, 1);
    transition-delay: var(--delay, 0ms);
  }
  .reveal-scale.in-view { opacity: 1; transform: scale(1) translateY(0); }
  .reveal-blur {
    opacity: 0; transform: translateY(36px); filter: blur(16px); will-change: opacity, transform, filter;
    transition: opacity 1.15s cubic-bezier(0.16, 1, 0.3, 1), transform 1.15s cubic-bezier(0.16, 1, 0.3, 1), filter 0.95s cubic-bezier(0.16, 1, 0.3, 1);
    transition-delay: var(--delay, 0ms);
  }
  .reveal-blur.in-view { opacity: 1; transform: translateY(0); filter: blur(0); }

  /* ─── RESPONSIVE ─── */
