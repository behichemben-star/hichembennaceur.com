---
interface Props {
  title?: string;
  description?: string;
  canonicalUrl?: string;
}

const {
  title = "Hichem Bennaceur — Analytics & CRO Retainer | 3× Output, ¼ Agency Cost",
  description = "Senior Analytics & CRO as a retainer. 3× the depth of a freelancer at ¼ the cost of an agency. Real attribution, funnel fixes, and data your team can act on.",
  canonicalUrl = "https://hichembennaceur.com/",
} = Astro.props;

const ogImage = "https://hichembennaceur.com/images/og-social-preview.png";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content="Hichem Bennaceur" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:alt" content="Hichem Bennaceur — Analytics & CRO consultant" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:site_name" content="Hichem Bennaceur" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content="Hichem Bennaceur — Analytics & CRO consultant" />

    <!-- Sitemap -->
    <link rel="sitemap" type="application/xml" href="/sitemap.xml" />

    <link rel="icon" type="image/png" href="/images/profile-main.png" />
    <link rel="apple-touch-icon" href="/images/profile-main.png" />
    <title>{title}</title>
    <!-- Font preconnects -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://api.fontshare.com" />
    <link rel="preconnect" href="https://cdn.fontshare.com" crossorigin />

    <!-- Fonts (non-render-blocking) -->
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Archivo:ital,wght@0,400;0,500;0,600;0,700;0,800;0,900;1,400;1,700&family=Archivo+Black&family=DM+Mono:wght@400;500&display=swap" />
    <link rel="stylesheet" href="https://api.fontshare.com/v2/css?f[]=satoshi@900,700,500,400&display=swap" />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "Person",
          "@id": "https://hichembennaceur.com/#person",
          "name": "Hichem Bennaceur",
          "url": "https://hichembennaceur.com/",
          "image": "https://hichembennaceur.com/images/profile-main.png",
          "jobTitle": "CRO & Analytics Consultant",
          "description": "Senior CRO and Analytics specialist helping DTC brands, SaaS companies, and agencies scale revenue through experimentation and data-driven optimisation.",
          "sameAs": [
            "https://www.linkedin.com/in/hichembennaceur/"
          ]
        },
        {
          "@type": "WebSite",
          "@id": "https://hichembennaceur.com/#website",
          "url": "https://hichembennaceur.com/",
          "name": "Hichem Bennaceur",
          "description": "Senior Analytics & CRO as a retainer. 3× the depth of a freelancer at ¼ the cost of an agency.",
          "publisher": { "@id": "https://hichembennaceur.com/#person" }
        }
      ]
    })} />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  /* ─── Neobrutalism Design Tokens ─── */
  :root {
    --yellow: #FDC800;
    --blue: #432DD7;
    --green: #16A34A;
    --red: #DC2626;
    --orange: #F97316;
    --black: #0A0A0A;
    --white: #FAFAF7;
    --surface: #F0EFE8;
    --text: #0A0A0A;
    --text-muted: #555;
    --border: 3px solid #0A0A0A;
    --shadow: 5px 5px 0px #0A0A0A;
    --shadow-lg: 8px 8px 0px #0A0A0A;
    --shadow-sm: 3px 3px 0px #0A0A0A;
    --font-display: 'Archivo Black', sans-serif;
    --font-body: 'Archivo', sans-serif;
    --font-mono: 'DM Mono', monospace;
  }

  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html { scroll-behavior: smooth; }

  body {
    font-family: var(--font-body);
    background-color: var(--white);
    color: var(--text);
    line-height: 1.6;
    overflow-x: hidden;
  }

  img { max-width: 100%; display: block; }
  a { color: inherit; text-decoration: none; }

  ::-webkit-scrollbar { width: 6px; }
  ::-webkit-scrollbar-track { background: var(--surface); }
  ::-webkit-scrollbar-thumb { background: var(--black); }
  :focus-visible { outline: 3px solid var(--blue); outline-offset: 3px; }
</style>
